{
  "name": "prettyfish",
  "version": "0.1.0",
  "description": "A browser-based Mermaid diagram editor with live preview, multi-page projects, and offline support.",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://github.com/pastelsky/prettyfish",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pastelsky/prettyfish.git"
  },
  "bugs": {
    "url": "https://github.com/pastelsky/prettyfish/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "seo:generate": "node --experimental-strip-types scripts/generate-seo-pages.mjs",
    "dev": "npm run seo:generate && vite",
    "build": "npm run seo:generate && vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint . --max-warnings 0 && npm run check:dark",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "validate-examples": "node --experimental-strip-types scripts/validate-examples.mjs",
    "check:dark": "node scripts/check-dark-equivalents.mjs",
    "check:dark:update-baseline": "node scripts/check-dark-equivalents.mjs --update-baseline",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:report": "playwright show-report",
    "perf:workspace": "node scripts/measure-large-workspace.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@codemirror/lang-json": "^6.0.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.2.2",
    "@uiw/codemirror-theme-github": "^4.25.9",
    "@uiw/codemirror-theme-vscode": "^4.25.9",
    "@uiw/react-codemirror": "^4.25.9",
    "@xyflow/react": "^12.10.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror-lang-mermaid": "^0.5.0",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^1.7.0",
    "mermaid": "^11.14.0",
    "mermaid-formatter": "^0.3.0",
    "posthog-js": "^1.364.7",
    "react": "^19.2.4",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.4",
    "react-hotkeys-hook": "^5.2.4",
    "react-split-pane": "^3.2.0",
    "react-zoom-pan-pinch": "^3.7.0",
    "shadcn": "^4.1.2",
    "shiki": "^4.0.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@cloudflare/vite-plugin": "^1.31.0",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-plugin-react-compiler": "^19.1.0-rc.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "jsdom": "^29.0.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-istanbul": "^8.0.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2",
    "workbox-window": "^7.4.0",
    "wrangler": "^4.80.0"
  }
}
